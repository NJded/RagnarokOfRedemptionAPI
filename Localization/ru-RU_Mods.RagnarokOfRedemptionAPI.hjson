	BurningGrace: {
		DisplayName: Burning Grace
		Tooltip:
			'''
			8% increased healing speed
			12% increased Holy elemental damage and resistance
			6% increased Holy and Fire elemental critical strike chance
			Stacks if both elements are present
			Healing an ally increases their life regeneration and regeneration rate
			Healing spells will increase the healed targets defense by 14 for 20 seconds
			Critical strikes with a Holy elemental weapon or using healing tools has a chance to release homing lightmass
			An aura of holy flames surrounds you while holding a Fire or Holy elemental weapon
			Aura is empowered while holding a Healer tool
			Increases length of invincibility after taking damage
			'''
	}

	AmbrosialAmpoule.ExtraTooltip:
		'''
		Friendly blue flies will occasionally appear to protect you
		Any flies that target you will transform into blue flies
		Critters are attracted to you and shy critters won't fear you
		Bees and Spider Swarmers become passive
		Grants immunity to Webbed
		'''

	NanoCore: {
		DisplayName: Nano Core
		Tooltip:
			'''
			Creates a nanoshield around the wearer:
			Increases max movement speed and acceleration while underwater
			Grants the ability to swim, extends underwater breathing, emits light underwater, and improves mobility on ice
			Provides a moderate amount of light, reduces breath loss, and reduces damage caused by drowning in the abyss
			Abyss creatures are less likely to see you, mitigates the abyss' defense reduction, and lets you sink faster in liquids
			Grants immunity to the Abandoned Lab, Wasteland and Sulfurous water
			Grants immunity to [cbuff:CalamityMod/CrushDepth] , [cbuff:Redemption/RadioactiveFalloutDebuff] and all infection debuffs
			Grants resistance to the increased breath loss caused by [cbuff:CalamityMod/HadopelagicPressure]
			Grants protection against up radiation protection
			'''
	}

