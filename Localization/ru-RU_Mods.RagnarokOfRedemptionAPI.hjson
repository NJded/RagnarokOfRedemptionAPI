	BurningGrace: {
		DisplayName: Пылающая благодать
		Tooltip:
			'''
			Увеличивает скорость лечения на 8%
			Увеличивает урон и сопротивление {0} на 12%
			Увеличивает шанс критического удара {0} и {1} на 6%
			Эффекты суммируются при наличии обоих элементов
			Лечение союзника значительно увеличивает его регенерацию здоровья
			Исцеляющие заклинания увеличивают защиту исцеляемой цели на 14 единиц в течение 20 секунд
			Критические удары элементальным оружием {0} могут высвободить самонаводящуюся светомассу
			При использовании элементального оружия {1} или {0} вас окружает аура священного пламени
			Аура усиливается при использовании оружий целителя
			Увеличивает длительность неуязвимости после получения урона
			'''
	}

	AmbrosialAmpoule.ExtraTooltip:
		'''
		Время от времени рядом с вами будут появляться дружелюбные синие мухи, которые будут вас защищать
		Любые мухи, нападающие на вас, превращаются в синих
		Вы привлекаете живность, а пугливая живность больше не боится вас
		Пчёлы становятся пассивными
		Роевые пауки становятся пассивными
		Даёт невосприимчивость к дебаффу «Паутина»
		'''

	NanoCore: {
		DisplayName: Нано-ядро
		Tooltip:
			'''
			Превращает владельца в бронированного водолаза:
			Увеличивает максимальную скорость передвижения и ускорение под водой
			Позволяет плавать, увеличивает запас воздуха под водой, излучает свет под водой и увеличивает подвижность на льду
			Излучает умеренное количество света, снижает расход воздуха и урон от удушья в бездне
			Делает вас менее заметным для существ бездны, смягчает снижение защиты, вызванное бездной, и позволяет быстрее погружаться в жидкости
			Даёт невосприимчивость к водам заброшенной лаборатории , пустоши и сернистых вод
			Даёт невосприимчивость к дебаффам [cbuff:CalamityMod/CrushDepth] , [cbuff:Redemption/RadioactiveFalloutDebuff] и всем дебаффам заражения
			Даёт устойчивость к увеличенной потере воздуха, вызванной дебаффом [cbuff:CalamityMod/HadopelagicPressure]
			Даёт защиту от радиации высокого уровня
			'''
	}

	GirusDecoder: {
