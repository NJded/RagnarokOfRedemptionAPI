	BurningGrace: {
		DisplayName: 炽焰恩典
		Tooltip:
			'''
			增加8%治疗速度
			增加12%神圣元素伤害与抗性
			增加6%神圣与火元素暴击率
			若两种元素同时存在则可叠加
			治疗队友会提升其生命再生量与再生速度
			治疗法术会使受治疗目标的防御提升14，持续20秒
			用神圣元素武器打出暴击或使用治疗工具时，有概率释放追踪光雨
			手持火或神圣元素武器时，圣焰光环将环绕于你
			手持牧师工具时，光环得到强化
			延长受伤后的无敌时间
			'''
	}

	AmbrosialAmpoule.ExtraTooltip:
		'''
		友善的蓝色苍蝇会不时出现守护你
		任何以你为目标的苍蝇都会化作蓝色苍蝇
		小动物会为你所吸引，胆怯的生灵也不再惧怕你
		蜜蜂与蜘蛛蜂拥者变得温顺
		免疫被网住减益
		'''

	NanoCore: {
		DisplayName: 纳米核心
		Tooltip:
			'''
			在佩戴者周身生成一层纳米护盾：
			提升水下的最大移动速度与加速度
			赋予使用者游泳能力，延长水下呼吸，在水下发光，并提升冰面上的行动力
			在水下提供适量光照，减缓氧气流失，并降低在深渊中溺水所受的伤害
			深渊生物更难察觉你，减轻深渊的防御削减效果，并让你在液体中下沉更快
			免疫废弃实验室、废土与硫磺海水的影响
			免疫[cbuff:CalamityMod/CrushDepth]、[cbuff:Redemption/RadioactiveFalloutDebuff]及一切疾病系减益
			提供对[cbuff:CalamityMod/HadopelagicPressure]所导致的额外氧气流失效果的抗性
			提供额外的辐射防护
			'''
	}

	GirusDecoder: {
		DisplayName: 吉鲁斯解码器
		Tooltip:
			'''
			能放置在密码破译器基站上
			让你得以解密欧米伽数据面板
			解密后，你能够合成新的物品
			'''
	}

